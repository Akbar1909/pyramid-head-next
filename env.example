# Copy to .env.local for development or .env for PM2 production (see ecosystem.config.cjs).

# ── API ──────────────────────────────────────────────────────────────────────
# NestJS backend (no trailing slash). Default: http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3000

# ── Next.js app ──────────────────────────────────────────────────────────────
# Dev: 3001 (see package.json "dev" script). Prod PM2: 3400 (ecosystem.config.cjs)
PORT=3001

# ── NextAuth (Auth.js v5) ────────────────────────────────────────────────────
# Required. Generate: openssl rand -base64 32
AUTH_SECRET=

# Public URL of this Next admin app (no trailing slash).
# Dev:
AUTH_URL=http://localhost:3001
# Prod example:
# AUTH_URL=https://canadiancollegepyramid.com

# Locales: src/i18n/routing.ts (en, az). URLs use a prefix, e.g. /en/dashboard.
